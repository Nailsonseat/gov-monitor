# Database Configuration (CockroachDB Cloud URI)
# Ensure you append sslrootcert=ca.pem to tell SQLAlchemy where to look
DATABASE_URL=postgresql://<username>:<password>@<host>:26257/gov_monitor?sslmode=verify-full&sslrootcert=ca.pem

# Database Certificate Content
# When pasting your actual cert in your real .env, replace actual line breaks with \n
DB_CA_CERT="-----BEGIN CERTIFICATE-----\nYOUR_CERT_CONTENT_HERE\n-----END CERTIFICATE-----"

# Third Party APIs
DATA_GOV_IN_API_KEY=your_datagov_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Pipeline Settings
TARGET_CITY=Pune
TARGET_DISTRICT=Pune
LANGUAGE_TARGET=Marathi